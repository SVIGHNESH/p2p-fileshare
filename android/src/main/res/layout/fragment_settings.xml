<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1419"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Network Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Network - Tracker Connection"
            android:textColor="#B3C0CC"
            android:textSize="15sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_globe"
            android:drawableTint="#B3C0CC"
            android:drawablePadding="10dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp" />

        <!-- Info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-discovery is ON by default"
                android:textColor="#58A8FF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_info"
                android:drawableTint="#58A8FF"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The app will find the tracker automatically on your Wi-Fi. Only enter an IP below if auto-discovery doesn't work."
                android:textColor="#93A1AE"
                android:textSize="13sp"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Tracker IP -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tracker IP Address (optional)"
            android:textColor="#B3C0CC"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/tracker_host_field"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="e.g. 192.168.1.10"
            android:textColorHint="#5E6B77"
            android:textColor="#FFFFFF"
            android:background="@drawable/search_field_bg"
            android:padding="12dp"
            android:textSize="14sp"
            android:inputType="text"
            android:layout_marginBottom="12dp" />

        <!-- Tracker Port -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tracker Port"
            android:textColor="#B3C0CC"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/tracker_port_field"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="9000"
            android:textColorHint="#5E6B77"
            android:textColor="#FFFFFF"
            android:background="@drawable/search_field_bg"
            android:padding="12dp"
            android:textSize="14sp"
            android:inputType="number"
            android:layout_marginBottom="24dp" />

        <!-- Display Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your Display Name"
            android:textColor="#B3C0CC"
            android:textSize="15sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_user"
            android:drawableTint="#B3C0CC"
            android:drawablePadding="10dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/display_name_field"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Your name"
            android:textColorHint="#5E6B77"
            android:textColor="#FFFFFF"
            android:background="@drawable/search_field_bg"
            android:padding="12dp"
            android:textSize="14sp"
            android:inputType="text"
            android:layout_marginBottom="24dp" />

        <!-- Security card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0E1F16"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Encryption: Always On"
                android:textColor="#46C46A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_lock"
                android:drawableTint="#46C46A"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All transfers are encrypted with TLS 1.3 and verified with SHA-256. No setup needed."
                android:textColor="#7FB892"
                android:textSize="13sp"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Save button -->
        <Button
            android:id="@+id/save_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Settings"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/button_primary" />

        <!-- About Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About"
            android:textColor="#B3C0CC"
            android:textSize="15sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_info"
            android:drawableTint="#B3C0CC"
            android:drawablePadding="10dp"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Created by Vighnesh Shukla"
            android:textColor="#93A1AE"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
